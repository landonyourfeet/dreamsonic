# DreamSonic — environment variables
# Copy to .env for local development. On Railway, set these in the service Variables tab.

# Postgres connection string. Railway Postgres provides this automatically when you attach the DB.
DATABASE_URL=postgres://user:pass@host:5432/dreamsonic

# Optional: override port (Railway sets this automatically, default is 3000 locally)
# PORT=3000

# Optional: Node environment. Railway sets "production" by default.
# NODE_ENV=development
